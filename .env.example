# ── Copy these into Vercel Environment Variables ──────────────────────────────
# Go to: Vercel Dashboard → Your Project → Settings → Environment Variables

# Supabase (database + auth)
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Modal endpoint URL (after deploying modal_llm_server.py)
REACT_APP_RUNPOD_ENDPOINT=https://llm-server-serve.runpod

# Your custom API key (must match MY_API_KEY in Modal secret)
REACT_APP_API_KEY=void_sk_your_strong_random_key_here

# Tavily web search (tavily.com → Dashboard → API Keys)
REACT_APP_TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 file storage
# NOTE: R2 credentials are sensitive — these are used server-side only
# For a pure frontend app, store R2 uploads via a Modal backend proxy instead
# OR use Supabase Storage as the primary (simpler, already configured)
# These are kept here for reference when building the Modal backend
REACT_APP_R2_ACCOUNT_ID=your_account_id
REACT_APP_R2_BUCKET_NAME=void-media
REACT_APP_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
